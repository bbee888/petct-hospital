# 环境变量配置示例
# 复制此文件为 .env.development 或 .env.production 并修改相应值

# ====================
# API配置
# ====================
# 后端API地址(不包含/api路径)
# 开发环境示例: http://localhost:8001
# 生产环境示例: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8001

# ====================
# 应用配置
# ====================
# 前端应用端口
VITE_APP_PORT=8080

# ====================
# 使用说明
# ====================
# 1. 复制此文件为 .env.development (开发环境)
# 2. 复制此文件为 .env.production (生产环境)
# 3. 修改相应环境下的配置值
# 4. 所有VITE_开头的变量会在构建时自动注入
